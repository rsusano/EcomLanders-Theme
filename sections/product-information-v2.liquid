{{ 'section-product-v2.css' | asset_url | stylesheet_tag }}
<script src="{{ 'section-product-v2.js' | asset_url }}" defer></script>

{%- liquid
  assign product = section.settings.product | default: product
  assign current_variant = product.selected_or_first_available_variant
  assign thumb_pos = section.settings.gallery_thumb_position | default: 'bottom'
-%}

{%- comment -%} --- CSS variables from schema settings --- {%- endcomment -%}
<style>
  #shopify-section-{{ section.id }} .piv2 {
    --piv2-primary: {{ section.settings.primary_color }};
    --piv2-primary-dark: {{ section.settings.primary_dark_color }};
    --piv2-primary-light: {{ section.settings.primary_light_color }};
    --piv2-primary-border: {{ section.settings.primary_border_color }};
    --piv2-accent: {{ section.settings.accent_color }};
    --piv2-star: {{ section.settings.star_color }};
    --piv2-text: {{ section.settings.text_color }};
    --piv2-text-muted: {{ section.settings.text_muted_color }};
    --piv2-bg: {{ section.settings.bg_color }};
    --piv2-border: {{ section.settings.border_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
</style>

<section
  class="piv2"
  data-section-type="product-information-v2"
  id="shopify-section-{{ section.id }}"
>
  <div class="piv2__wrapper">
    <div class="piv2__grid">

      {%- comment -%} ================================
        LEFT COLUMN — GALLERY + FEATURE ICONS
      ================================ {%- endcomment -%}
      <div class="piv2__left">

        {%- comment -%} GALLERY {%- endcomment -%}
        <div class="piv2-gallery piv2-gallery--thumbs-{{ thumb_pos }}" data-piv2-gallery>

          {%- comment -%} LEFT thumbnails {%- endcomment -%}
          {%- if product != blank and product.media.size > 1 and thumb_pos == 'left' -%}
            <div class="piv2-gallery__thumbs">
              {%- for media in product.media -%}
                <div
                  class="piv2-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                  data-piv2-thumb
                  aria-label="Image {{ forloop.index }}"
                >
                  <img
                    src="{{ media | image_url: width: 120 }}"
                    alt="{{ media.alt | default: product.title | escape }}"
                    width="120"
                    height="120"
                    loading="lazy"
                  >
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%} Main Image Wrap {%- endcomment -%}
          <div class="piv2-gallery__main-wrap">
            <div class="piv2-gallery__main">
              {%- if product != blank and product.media.size > 0 -%}
                <img
                  class="piv2-gallery__main-img"
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | default: product.title | escape }}"
                  width="800"
                  height="800"
                  loading="eager"
                  fetchpriority="high"
                  data-piv2-main-img
                >
              {%- else -%}
                {{ 'product-1' | placeholder_svg_tag: 'piv2-gallery__main-img placeholder-svg placeholder-svg--product' }}
              {%- endif -%}

              {%- comment -%} Hidden media data for JS {%- endcomment -%}
              {%- if product != blank -%}
                {%- for media in product.media -%}
                  <span
                    data-piv2-media
                    data-src="{{ media | image_url: width: 800 }}"
                    data-alt="{{ media.alt | default: product.title | escape }}"
                    style="display:none;"
                  ></span>
                {%- endfor -%}
              {%- endif -%}

              {%- comment -%} Bestseller Badge {%- endcomment -%}
              {%- if section.settings.show_badge and section.settings.badge_text != blank -%}
                <div class="piv2-gallery__badge">
                  <svg viewBox="0 0 12 12" xmlns="http://www.w3.org/2000/svg">
                    <path d="M6 0L7.347 4.146H11.706L8.18 6.708 9.527 10.854 6 8.292 2.473 10.854 3.82 6.708.294 4.146H4.653z"/>
                  </svg>
                  {{ section.settings.badge_text }}
                </div>
              {%- endif -%}

              <button class="piv2-gallery__nav piv2-gallery__nav--prev" data-piv2-prev aria-label="Previous image">
                <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="piv2-gallery__nav piv2-gallery__nav--next" data-piv2-next aria-label="Next image">
                <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
          </div>{%- comment -%} end main-wrap {%- endcomment -%}

          {%- comment -%} BOTTOM thumbnails (default) {%- endcomment -%}
          {%- if product != blank and product.media.size > 1 and thumb_pos == 'bottom' -%}
            <div class="piv2-gallery__thumbs">
              {%- for media in product.media -%}
                <div
                  class="piv2-gallery__thumb{% if forloop.first %} is-active{% endif %}"
                  data-piv2-thumb
                  aria-label="Image {{ forloop.index }}"
                >
                  <img
                    src="{{ media | image_url: width: 120 }}"
                    alt="{{ media.alt | default: product.title | escape }}"
                    width="120"
                    height="120"
                    loading="lazy"
                  >
                </div>
              {%- endfor -%}
            </div>
          {%- endif -%}

        </div>{%- comment -%} end gallery {%- endcomment -%}

        {%- comment -%} Left column blocks (page-builder style) {%- endcomment -%}

        {%- if section.settings.show_features -%}
          <div class="piv2-features" data-piv2-features>
            {%- for block in section.blocks -%}
              {%- if block.type == 'feature_icon' -%}
                {%- assign block_column = block.settings.column -%}
                {%- if block_column == blank or block_column == 'left' -%}
                  {%- assign feature_classes = 'piv2-feature' -%}
                  {%- if block.settings.hide_on_desktop -%}
                    {%- assign feature_classes = feature_classes | append: ' piv2--hide-desktop' -%}
                  {%- endif -%}
                  {%- if block.settings.hide_on_mobile -%}
                    {%- assign feature_classes = feature_classes | append: ' piv2--hide-mobile' -%}
                  {%- endif -%}
                  {%- assign spacing_style = '' -%}
                  {%- if block.settings.margin_top and block.settings.margin_top > 0 -%}
                    {%- assign spacing_style = spacing_style | append: 'margin-top:' | append: block.settings.margin_top | append: 'px;' -%}
                  {%- endif -%}
                  {%- if block.settings.margin_bottom and block.settings.margin_bottom > 0 -%}
                    {%- assign spacing_style = spacing_style | append: 'margin-bottom:' | append: block.settings.margin_bottom | append: 'px;' -%}
                  {%- endif -%}
                  <div class="{{ feature_classes }}" {% unless spacing_style == '' %}style="{{ spacing_style }}"{% endunless %} {{ block.shopify_attributes }}>
                    {%- if block.settings.icon_image != blank -%}
                      <img
                        class="piv2-feature__icon"
                        src="{{ block.settings.icon_image | image_url: width: 80 }}"
                        alt="{{ block.settings.label | escape }}"
                        width="40"
                        height="40"
                        loading="lazy"
                      >
                    {%- else -%}
                      <div class="piv2-feature__icon--svg">
                        {%- case block.settings.icon_preset -%}
                          {%- when 'joint' -%}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2C8.686 2 6 4.686 6 8c0 2.21.895 4.21 2.343 5.657A8 8 0 1 0 12 2zm0 2a6 6 0 1 1 0 12A6 6 0 0 1 12 4zm0 2a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" fill="currentColor"/></svg>
                          {%- when 'lab' -%}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 2v7.29L5.5 17A3 3 0 0 0 8.28 21h7.44A3 3 0 0 0 18.5 17L15 9.29V2H9zm2 2h2v5.71l.43.79L16.3 19a1 1 0 0 1-.86 1H8.56a1 1 0 0 1-.86-1l2.87-8.5.43-.79V4z" fill="currentColor"/></svg>
                          {%- when 'relief' -%}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm0 2a8 8 0 1 1 0 16A8 8 0 0 1 12 4zm-1 4v4H7l5 6 5-6h-4V8h-2z" fill="currentColor"/></svg>
                          {%- when 'shield' -%}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M12 2L4 6v6c0 5.25 3.5 10.15 8 11.35C16.5 22.15 20 17.25 20 12V6l-8-4zm0 2.18L18 7.3V12c0 4.08-2.7 7.88-6 9.14C8.7 19.88 6 16.08 6 12V7.3l6-3.12z" fill="currentColor"/></svg>
                          {%- else -%}
                            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" fill="currentColor"/></svg>
                        {%- endcase -%}
                      </div>
                    {%- endif -%}
                    <span class="piv2-feature__label">{{ block.settings.label }}</span>
                  </div>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}

        {%- for block in section.blocks -%}
          {%- assign block_column = block.settings.column -%}
          {%- if block_column == 'left' and block.type != 'feature_icon' -%}
            {%- case block.type -%}
              {%- when 'benefit' -%}
                {%- assign spacing_style = '' -%}
                {%- if block.settings.margin_top and block.settings.margin_top > 0 -%}
                  {%- assign spacing_style = spacing_style | append: 'margin-top:' | append: block.settings.margin_top | append: 'px;' -%}
                {%- endif -%}
                {%- if block.settings.margin_bottom and block.settings.margin_bottom > 0 -%}
                  {%- assign spacing_style = spacing_style | append: 'margin-bottom:' | append: block.settings.margin_bottom | append: 'px;' -%}
                {%- endif -%}
                <div class="piv2-block" {% unless spacing_style == '' %}style="{{ spacing_style }}"{% endunless %} {{ block.shopify_attributes }}>
                  <ul class="piv2-benefits piv2-benefits--desktop-{{ section.settings.benefits_layout_desktop | default: 'two-column' }} piv2-benefits--mobile-{{ section.settings.benefits_layout_mobile | default: 'one-column' }}">
                    <li class="piv2-benefits__item">
                      <span class="piv2-benefits__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                      </span>
                      {{ block.settings.text }}
                    </li>
                  </ul>
                </div>

              {%- when 'trust_signal' -%}
                {%- assign spacing_style = '' -%}
                {%- if block.settings.margin_top and block.settings.margin_top > 0 -%}
                  {%- assign spacing_style = spacing_style | append: 'margin-top:' | append: block.settings.margin_top | append: 'px;' -%}
                {%- endif -%}
                {%- if block.settings.margin_bottom and block.settings.margin_bottom > 0 -%}
                  {%- assign spacing_style = spacing_style | append: 'margin-bottom:' | append: block.settings.margin_bottom | append: 'px;' -%}
                {%- endif -%}
                <div class="piv2-trust__item" {% unless spacing_style == '' %}style="{{ spacing_style }}"{% endunless %} {{ block.shopify_attributes }}>
                  <span class="piv2-trust__icon piv2-trust__icon--{{ block.settings.icon_style }}">
                    {%- case block.settings.icon_style -%}
                      {%- when 'stock' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10"/>
                          <path d="M12 8v4l3 3"/>
                        </svg>
                      {%- when 'ship' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <rect x="1" y="3" width="15" height="13"/>
                          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                          <circle cx="5.5" cy="18.5" r="2.5"/>
                          <circle cx="18.5" cy="18.5" r="2.5"/>
                        </svg>
                      {%- when 'guarantee' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                      {%- when 'link' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10"/>
                          <line x1="12" y1="8" x2="12" y2="16"/>
                          <line x1="8" y1="12" x2="16" y2="12"/>
                        </svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    {%- endcase -%}
                  </span>
                  <span>
                    {{ block.settings.text }}
                    {%- if block.settings.show_country_flag and block.settings.country_name != blank -%}
                      &nbsp;
                      <img
                        class="piv2-trust__flag"
                        src="{{ block.settings.flag_image | image_url: width: 44 }}"
                        alt="{{ block.settings.country_name }}"
                        width="22"
                        height="15"
                        loading="lazy"
                      >
                      {{ block.settings.country_name }}
                    {%- endif -%}
                  </span>
                  {%- if block.settings.link_text != blank -%}
                    <button class="piv2-trust__link" type="button">
                      {{ block.settings.link_text }}
                    </button>
                  {%- endif -%}
                </div>

              {%- when 'accordion' -%}
                {%- assign spacing_style = '' -%}
                {%- if block.settings.margin_top and block.settings.margin_top > 0 -%}
                  {%- assign spacing_style = spacing_style | append: 'margin-top:' | append: block.settings.margin_top | append: 'px;' -%}
                {%- endif -%}
                {%- if block.settings.margin_bottom and block.settings.margin_bottom > 0 -%}
                  {%- assign spacing_style = spacing_style | append: 'margin-bottom:' | append: block.settings.margin_bottom | append: 'px;' -%}
                {%- endif -%}
                <details class="piv2-accordion" {% unless spacing_style == '' %}style="{{ spacing_style }}"{% endunless %} {{ block.shopify_attributes }}>
                  <summary class="piv2-accordion__trigger">
                    <span class="piv2-accordion__title">{{ block.settings.title }}</span>
                    <span class="piv2-accordion__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                      </svg>
                    </span>
                  </summary>
                  <div class="piv2-accordion__body">{{ block.settings.content }}</div>
                </details>

            {%- endcase -%}
          {%- endif -%}
        {%- endfor -%}

      </div>{%- comment -%} end left col {%- endcomment -%}

      {%- comment -%} ================================
        RIGHT COLUMN — PRODUCT INFO
      ================================ {%- endcomment -%}
      <div class="piv2-info">

        {%- comment -%} Fixed Header Elements {%- endcomment -%}
        {%- if section.settings.show_rating -%}
          {%- assign rating_classes = 'piv2-rating' -%}
          {%- unless section.settings.show_rating_desktop -%}
            {%- assign rating_classes = rating_classes | append: ' piv2--hide-desktop' -%}
          {%- endunless -%}
          {%- unless section.settings.show_rating_mobile -%}
            {%- assign rating_classes = rating_classes | append: ' piv2--hide-mobile' -%}
          {%- endunless -%}
          <div class="{{ rating_classes }}">
            <div class="piv2-rating__stars" aria-label="{{ section.settings.rating_score }} out of 5 stars">
              {%- assign full_stars = section.settings.rating_score | floor -%}
              {%- for i in (1..5) -%}
                <span class="piv2-rating__star{% if i <= full_stars %} is-filled{% endif %}" aria-hidden="true">
                  <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path d="M12 2l2.92 5.92 6.53.95-4.72 4.6 1.12 6.51L12 17.77 6.15 20.98l1.12-6.51-4.72-4.6 6.53-.95z" />
                  </svg>
                </span>
              {%- endfor -%}
            </div>
            <span class="piv2-rating__text">Rated <strong>{{ section.settings.rating_score }} Excellent</strong> | {{ section.settings.rating_count }}+ Customers</span>
          </div>
        {%- endif -%}

        <div>
          {%- if section.settings.brand_name != blank -%}<p class="piv2__brand">{{ section.settings.brand_name }}</p>{%- endif -%}
          <h1 class="piv2__title">{%- if product != blank -%}{{ product.title }}{%- else -%}{{ section.settings.product_title | default: 'Product Title' }}{%- endif -%}</h1>
          {%- if section.settings.product_subtitle != blank -%}<p class="piv2__subtitle">{{ section.settings.product_subtitle }}</p>{%- endif -%}
        </div>

        {%- comment -%} Dynamic Block Rendering {%- endcomment -%}
        {%- assign bundle_rendered = false -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature_icon' or block.settings.column == 'left' -%}
            {%- continue -%}
          {%- endif -%}

          {%- assign block_classes = 'piv2-block' -%}
          {%- if block.settings.hide_on_desktop -%}
            {%- assign block_classes = block_classes | append: ' piv2--hide-desktop' -%}
          {%- endif -%}
          {%- if block.settings.hide_on_mobile -%}
            {%- assign block_classes = block_classes | append: ' piv2--hide-mobile' -%}
          {%- endif -%}

          {%- assign spacing_style = '' -%}
          {%- if block.settings.margin_top and block.settings.margin_top > 0 -%}
            {%- assign spacing_style = spacing_style | append: 'margin-top:' | append: block.settings.margin_top | append: 'px;' -%}
          {%- endif -%}
          {%- if block.settings.margin_bottom and block.settings.margin_bottom > 0 -%}
            {%- assign spacing_style = spacing_style | append: 'margin-bottom:' | append: block.settings.margin_bottom | append: 'px;' -%}
          {%- endif -%}

          <div class="{{ block_classes }}" {% unless spacing_style == '' %}style="{{ spacing_style }}"{% endunless %} {{ block.shopify_attributes }}>
            {%- case block.type -%}
              {%- when 'benefit' -%}
                <ul class="piv2-benefits piv2-benefits--desktop-{{ section.settings.benefits_layout_desktop | default: 'two-column' }} piv2-benefits--mobile-{{ section.settings.benefits_layout_mobile | default: 'one-column' }}">
                  <li class="piv2-benefits__item">
                    <span class="piv2-benefits__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <polyline points="20 6 9 17 4 12"/>
                      </svg>
                    </span>
                    {{ block.settings.text }}
                  </li>
                </ul>

              {%- when 'bundle' -%}
                {%- if bundle_rendered == false -%}
                  <div data-piv2-bundles data-piv2-subscribe-discount="{{ section.settings.subscription_discount }}">
                    <p class="piv2-bundles__heading">{{ section.settings.quantity_heading }}</p>

                    <div class="piv2-bundle-list">
                      {%- for b in section.blocks -%}
                        {%- if b.type == 'bundle' -%}
                          {%- liquid
                            assign split_price = b.settings.price | times: 100 | round
                            assign split_compare = b.settings.compare_price | times: 100 | round
                            assign split_price_f = b.settings.price | money
                            assign split_compare_f = b.settings.compare_price | money
                            if b.settings.variant_id != blank
                              assign bv = product.variants | where: 'id', b.settings.variant_id | first
                              if bv
                                assign split_price = bv.price
                                assign split_compare = bv.compare_at_price
                                assign split_price_f = bv.price | money
                                assign split_compare_f = bv.compare_at_price | money
                              endif
                            endif
                          -%}
                          {%- assign has_social_proof = false -%}
                          {%- if section.settings.social_proof_text != blank and forloop.index == section.settings.social_proof_position -%}
                            <div class="piv2-social-proof">{{ section.settings.social_proof_text }}</div>
                            {%- assign has_social_proof = true -%}
                          {%- endif -%}

                          <div
                            class="piv2-bundle{% if has_social_proof %} piv2-bundle--has-proof{% endif %}"
                            data-piv2-bundle
                            data-price="{{ split_price }}"
                            data-compare-price="{{ split_compare }}"
                            data-price-formatted="{{ split_price_f }}"
                            data-compare-price-formatted="{{ split_compare_f }}"
                            data-variant-id="{{ b.settings.variant_id | default: current_variant.id }}"
                            data-selling-plan-id="{{ b.settings.selling_plan_id }}"
                            data-index="{{ forloop.index0 }}"
                            {{ b.shopify_attributes }}
                          >
                            <div class="piv2-bundle__radio"></div>
                            <div class="piv2-bundle__img-wrap">
                              {%- if b.settings.bundle_image != blank -%}
                                <img
                                  class="piv2-bundle__img"
                                  src="{{ b.settings.bundle_image | image_url: width: 104 }}"
                                  alt="{{ b.settings.title | escape }}"
                                  width="52"
                                  height="52"
                                  loading="lazy"
                                >
                              {%- elsif product != blank and product.featured_image != blank -%}
                                <img
                                  class="piv2-bundle__img"
                                  src="{{ product.featured_image | image_url: width: 104 }}"
                                  alt="{{ product.title | escape }}"
                                  width="52"
                                  height="52"
                                  loading="lazy"
                                >
                              {%- else -%}
                                {{ 'product-1' | placeholder_svg_tag: 'piv2-bundle__img placeholder-svg' }}
                              {%- endif -%}
                              {%- if b.settings.save_badge != blank -%}
                                <div class="piv2-bundle__save">{{ b.settings.save_badge }}</div>
                              {%- endif -%}
                            </div>
                            <div class="piv2-bundle__content">
                              <p class="piv2-bundle__title">
                                {{ b.settings.title }}
                                {%- if b.settings.title_highlight != blank -%}
                                  <em>{{ b.settings.title_highlight }}</em>
                                {%- endif -%}
                              </p>
                              {%- if b.settings.subtitle != blank -%}
                                <p class="piv2-bundle__subtitle">{{ b.settings.subtitle }}</p>
                              {%- endif -%}
                            </div>
                            <div class="piv2-bundle__price">
                              <span class="piv2-bundle__price-now">{{ split_price_f }}</span>
                              {%- if split_compare > 0 and split_compare != split_price -%}
                                <span class="piv2-bundle__price-was">{{ split_compare_f }}</span>
                              {%- endif -%}
                            </div>
                            {%- if b.settings.popular_badge -%}
                              <div class="piv2-bundle__popular-badge">Best Value</div>
                            {%- endif -%}
                          </div>
                        {%- endif -%}
                      {%- endfor -%}
                    </div>

                    {%- if section.settings.show_subscription -%}
                      {%- assign sub_spacing = '' -%}
                      {%- if section.settings.subscription_margin_top and section.settings.subscription_margin_top > 0 -%}
                        {%- assign sub_spacing = sub_spacing | append: 'margin-top:' | append: section.settings.subscription_margin_top | append: 'px;' -%}
                      {%- endif -%}
                      {%- if section.settings.subscription_margin_bottom and section.settings.subscription_margin_bottom > 0 -%}
                        {%- assign sub_spacing = sub_spacing | append: 'margin-bottom:' | append: section.settings.subscription_margin_bottom | append: 'px;' -%}
                      {%- endif -%}
                      <div class="piv2-subscription" data-piv2-subscribe {% unless sub_spacing == '' %}style="{{ sub_spacing }}"{% endunless %}>
                        <div class="piv2-subscription__checkbox" data-piv2-subscribe-checkbox>
                          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <polyline points="20 6 9 17 4 12"/>
                          </svg>
                        </div>
                        <div>
                          <p class="piv2-subscription__title">{{ section.settings.subscription_title }}</p>
                          <p class="piv2-subscription__subtitle">{{ section.settings.subscription_subtitle }}</p>
                        </div>
                      </div>
                    {%- endif -%}

                    {%- assign atc_spacing = '' -%}
                    {%- if section.settings.atc_margin_top and section.settings.atc_margin_top > 0 -%}
                      {%- assign atc_spacing = atc_spacing | append: 'margin-top:' | append: section.settings.atc_margin_top | append: 'px;' -%}
                    {%- endif -%}
                    {%- if section.settings.atc_margin_bottom and section.settings.atc_margin_bottom > 0 -%}
                      {%- assign atc_spacing = atc_spacing | append: 'margin-bottom:' | append: section.settings.atc_margin_bottom | append: 'px;' -%}
                    {%- endif -%}
                    <button
                      class="piv2-atc"
                      data-piv2-atc
                      type="button"
                      {% unless atc_spacing == '' %}style="{{ atc_spacing }}"{% endunless %}
                      {%- unless current_variant.available -%}disabled{%- endunless -%}
                    >
                      <span>{{ section.settings.atc_button_text }}</span>
                      <span class="piv2-atc__price">
                        <span class="piv2-atc__price-now" data-piv2-price-now>
                          {%- if current_variant -%}{{ current_variant.price | money }}{%- endif -%}
                        </span>
                        {%- if current_variant.compare_at_price > current_variant.price -%}
                          <span class="piv2-atc__price-was" data-piv2-price-was>
                            {{ current_variant.compare_at_price | money }}
                          </span>
                        {%- endif -%}
                      </span>
                    </button>
                    <input type="hidden" name="id" value="{{ current_variant.id }}">
                  </div>
                  {%- assign bundle_rendered = true -%}
                {%- endif -%}

              {%- when 'trust_signal' -%}
                <div class="piv2-trust__item">
                  <span class="piv2-trust__icon piv2-trust__icon--{{ block.settings.icon_style }}">
                    {%- case block.settings.icon_style -%}
                      {%- when 'stock' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10"/>
                          <path d="M12 8v4l3 3"/>
                        </svg>
                      {%- when 'ship' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <rect x="1" y="3" width="15" height="13"/>
                          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
                          <circle cx="5.5" cy="18.5" r="2.5"/>
                          <circle cx="18.5" cy="18.5" r="2.5"/>
                        </svg>
                      {%- when 'guarantee' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        </svg>
                      {%- when 'link' -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <circle cx="12" cy="12" r="10"/>
                          <line x1="12" y1="8" x2="12" y2="16"/>
                          <line x1="8" y1="12" x2="16" y2="12"/>
                        </svg>
                      {%- else -%}
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" xmlns="http://www.w3.org/2000/svg">
                          <polyline points="20 6 9 17 4 12"/>
                        </svg>
                    {%- endcase -%}
                  </span>
                  <span>
                    {{ block.settings.text }}
                    {%- if block.settings.show_country_flag and block.settings.country_name != blank -%}
                      &nbsp;
                      <img
                        class="piv2-trust__flag"
                        src="{{ block.settings.flag_image | image_url: width: 44 }}"
                        alt="{{ block.settings.country_name }}"
                        width="22"
                        height="15"
                        loading="lazy"
                      >
                      {{ block.settings.country_name }}
                    {%- endif -%}
                  </span>
                  {%- if block.settings.link_text != blank -%}
                    <button class="piv2-trust__link" type="button">
                      {{ block.settings.link_text }}
                    </button>
                  {%- endif -%}
                </div>

              {%- when 'accordion' -%}
                <details class="piv2-accordion">
                  <summary class="piv2-accordion__trigger">
                    <span class="piv2-accordion__title">{{ block.settings.title }}</span>
                    <span class="piv2-accordion__icon" aria-hidden="true">
                      <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                      </svg>
                    </span>
                  </summary>
                  <div class="piv2-accordion__body">{{ block.settings.content }}</div>
                </details>

              {%- when 'review_video' -%}
                <div class="piv2-reviews__slide">
                  {%- if block.settings.thumbnail != blank -%}
                    <img
                      class="piv2-reviews__video-thumb"
                      src="{{ block.settings.thumbnail | image_url: width: 600 }}"
                      alt="{{ block.settings.alt | escape }}"
                      width="300"
                      height="450"
                      loading="lazy"
                    >
                  {%- else -%}
                    {{ 'lifestyle-1' | placeholder_svg_tag: 'piv2-reviews__video-thumb placeholder-svg' }}
                  {%- endif -%}
                  <div class="piv2-reviews__play-btn">
                    <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.4)"/>
                      <polygon points="10,8 17,12 10,16" fill="white"/>
                    </svg>
                  </div>
                </div>
            {%- endcase -%}
          </div>
        {%- endfor -%}

      </div>{%- comment -%} end right col {%- endcomment -%}

    </div>{%- comment -%} end grid {%- endcomment -%}
  </div>{%- comment -%} end wrapper {%- endcomment -%}

  {%- comment -%} ================================
    REVIEWS CAROUSEL (Full Width)
  ================================ {%- endcomment -%}
  {%- assign review_blocks = section.blocks | where: 'type', 'review_video' -%}
  {%- if review_blocks.size > 0 and section.settings.show_reviews -%}
    <div class="piv2-reviews">
      <h2 class="piv2-reviews__heading">{{ section.settings.reviews_heading }}</h2>

      <div class="piv2-reviews__carousel" data-piv2-reviews>
        <div class="piv2-reviews__track" data-piv2-reviews-track>
          {%- for block in review_blocks -%}
            <div class="piv2-reviews__slide" data-piv2-review-slide {{ block.shopify_attributes }}>
              {%- if block.settings.thumbnail != blank -%}
                <img
                  class="piv2-reviews__video-thumb"
                  src="{{ block.settings.thumbnail | image_url: width: 600 }}"
                  alt="{{ block.settings.alt | default: 'Customer review' | escape }}"
                  width="600"
                  height="900"
                  loading="lazy"
                >
              {%- else -%}
                {{ 'lifestyle-1' | placeholder_svg_tag: 'piv2-reviews__video-thumb placeholder-svg' }}
              {%- endif -%}
              <div class="piv2-reviews__play-btn" aria-label="Play review video">
                <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.4)"/><polygon points="10,8 17,12 10,16" fill="white"/></svg>
              </div>
            </div>
          {%- endfor -%}
        </div>

        <div class="piv2-reviews__controls">
          <button class="piv2-reviews__nav" data-piv2-reviews-prev aria-label="Previous">
            <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"/></svg>
          </button>
          <div class="piv2-reviews__dots">
            {%- for block in review_blocks -%}
              <button
                class="piv2-reviews__dot{% if forloop.first %} is-active{% endif %}"
                data-piv2-review-dot
                aria-label="Slide {{ forloop.index }}"
              ></button>
            {%- endfor -%}
          </div>
          <button class="piv2-reviews__nav" data-piv2-reviews-next aria-label="Next">
            <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"/></svg>
          </button>
        </div>
      </div>
    </div>
  {%- endif -%}

</section>

{% schema %}
{
